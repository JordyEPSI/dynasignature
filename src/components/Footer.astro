</footer>

<style>
    .main-footer {
        background-color: var(--color-bg);
        border-top: 1px solid rgba(28, 28, 28, 0.05); /* Ligne discrète pour séparer */
        padding-top: 60px;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr; /* La 1ère colonne est plus large */
        gap: 40px;
    }

    /* Style du logo texte (le même que le Header) */
    .logo {
        display: flex;
        flex-direction: column;
        line-height: 1;
        margin-bottom: 20px;
    }
    .logo-text {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        letter-spacing: 0.2em;
        color: var(--color-text);
    }
    .logo-subtext {
        font-size: 0.6rem;
        letter-spacing: 0.4em;
        color: #5A4636;
        margin-top: 4px;
    }

    .brand-desc {
        font-size: 0.8rem;
        line-height: 1.6;
        color: #5A4636;
        max-width: 250px;
    }

    /* Titres des colonnes */
    h4 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text);
        margin-bottom: 20px;
    }

    /* Listes de liens */
    ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    li {
        margin-bottom: 10px;
    }
    a {
        text-decoration: none;
        color: #5A4636;
        font-size: 0.8rem;
        transition: color 0.3s ease;
    }
    a:hover {
        color: var(--color-text);
        font-weight: bold;
    }

    /* Réseaux sociaux avec logos */
    .social-links {
        display: flex;
        gap: 15px;
    }
    .social-links a {
        color: var(--color-text); /* Noir doux par défaut */
        display: inline-flex; /* Aligne bien le SVG */
        transition: transform 0.3s ease, color 0.3s ease;
    }
    .social-links a:hover {
        color: var(--color-accent-dark); /* Passe au brun clair au survol */
        transform: translateY(-3px) scale(1.1); /* Remonte un peu et grossit */
    }

    /* Copyright */
    .footer-bottom {
        text-align: center;
        padding: 30px 20px;
        margin-top: 40px;
        border-top: 1px solid rgba(28, 28, 28, 0.05);
        font-size: 0.7rem;
        color: #5A4636;
    }

    /* RESPONSIVE FOOTER */
    @media (max-width: 900px) {
        /* Sur tablette : on fait 2 colonnes */
        .footer-container {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 600px) {
        /* Sur mobile : 1 seule colonne et on centre le texte */
        .footer-container {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .logo {
            align-items: center; /* Centre le logo */
        }
        .brand-desc {
            margin: 0 auto; /* Centre le paragraphe */
        }
        .social-links {
            justify-content: center; /* Centre les icônes */
        }
    }
</style>