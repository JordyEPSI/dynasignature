---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <section class="reservation-header">
        <div class="container text-center">
            <span class="text-subtitle">RÉSERVEZ VOTRE DATE</span>
            <h1>Vérifiez nos disponibilités</h1>
            <p>Sélectionnez la date de votre événement, choisissez vos options et validez votre acompte de manière 100% sécurisée.</p>
        </div>
    </section>

    <section class="booking-section">
        <div class="container">
            <div class="booking-box">
                
                <div class="calendly-inline-widget" data-url="https://calendly.com" style="min-width:320px;height:700px;">
                    <iframe 
                        src="https://calendly.com/fr" 
                        width="100%" 
                        height="100%" 
                        frameborder="0" 
                        title="Calendrier de réservation">
                    </iframe>
                </div>

            </div>
            
            <div class="reassurance">
                <div class="reassurance-item">
                    <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                    <span>Paiement sécurisé par Stripe</span>
                </div>
                <div class="reassurance-item">
                    <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>Confirmation immédiate</span>
                </div>
            </div>

        </div>
    </section>
</Layout>

<style>
    .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; }
    .text-center { text-align: center; }

    /* En-tête */
    .reservation-header {
        padding: 60px 20px 40px;
    }
    .reservation-header h1 {
        margin-bottom: 15px;
    }
    .reservation-header p {
        color: var(--color-muted);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* Boîte du calendrier */
    .booking-section {
        padding-bottom: 80px;
    }
    .booking-box {
        background-color: #FFFFFF; /* Fond blanc pur pour faire ressortir le calendrier */
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(28, 28, 28, 0.05); /* Légère ombre élégante */
        overflow: hidden; /* Empêche le calendrier de déborder des coins arrondis */
        border: 1px solid rgba(203, 187, 160, 0.3); /* Bordure discrète Beige sable */
    }

    /* Réassurance (Paiement sécurisé) */
    .reassurance {
        display: flex;
        justify-content: center;
        gap: 40px;
        margin-top: 30px;
    }
    .reassurance-item {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--color-muted);
        font-size: 0.8rem;
        font-weight: bold;
    }
    .reassurance-item svg {
        width: 18px;
        height: 18px;
        fill: var(--color-accent); /* Icône Champagne doré */
    }

    /* Responsive */
    @media (max-width: 600px) {
        .reassurance {
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }
    }
</style>