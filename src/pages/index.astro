---
import Welcome from '../components/Welcome.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="hero-section">
		<div class="hero-text">
			<span class="text-subtitle">CRÉATEURS DE SOUVENIRS</span>
			<h1>Nous capturons vos plus beaux moments.</h1>
			<p>Photobooth, Video Booth, Magazine Box : des expériences uniques pour sublimer vos événements.</p>
			<a href="/reservation" class="btn-primary">RÉSERVER UNE BORNE</a>
		</div>
		<div class="hero-image">
			IMAGE DE LA BORNE 360 ICI
		</div>
	</section>

	<section class="services-section">
		<div class="container text-center">
			<span class="text-subtitle">NOS CONCEPTS</span>
			<h2>Des expériences élégantes pour tous vos événements.</h2>
			
			<div class="services-grid">
				<div class="service-card">
					<h3>Photobooth</h3>
					<p>Des photos fun et élégantes pour des souvenirs instantanés.</p>
					<a href="#" class="link-more">EN SAVOIR PLUS →</a>
				</div>
				<div class="service-card">
					<h3>Video Booth 360</h3>
					<p>Des vidéos captivantes à partager et à revivre encore et encore.</p>
					<a href="#" class="link-more">EN SAVOIR PLUS →</a>
				</div>
				<div class="service-card">
					<h3>Magazine Box</h3>
					<p>Vos photos comme dans un magazine, une expérience unique et stylée.</p>
					<a href="#" class="link-more">EN SAVOIR PLUS →</a>
				</div>
			</div>
		</div>
	</section>

	<section class="pricing-section">
		<div class="container">
			<div class="text-center" style="margin-bottom: 50px;">
				<span class="text-subtitle">NOS FORMULES</span>
				<h2>Choisissez l'expérience Dynasignature</h2>
			</div>

			<div class="pricing-grid">
				<div class="price-card essentiel">
					<div class="card-header">
						<h3>Pack ESSENTIEL</h3>
						<div class="price">à partir de <span>299€</span></div>
						<p class="subtitle">Simple, efficace et accessible.</p>
					</div>
					<ul class="features-list">
						<li><strong>Vidéo-booth 360 pendant 2h</strong></li>
						<li>Installation et désinstallation incluses</li>
						<li>1 animateur sur place</li>
						<li>Éclairage LED standard</li>
						<li>Vidéos HD avec effets slow motion</li>
						<li>Partage instantané (QR Code / AirDrop)</li>
						<li>Accessoires classiques inclus</li>
					</ul>
					<div class="ideal-for">
						<strong>Idéal pour :</strong> Anniversaires, EVJF/EVG, Baby showers, Petits comités.
					</div>
					<a href="/reservation" class="btn-card">RÉSERVER L'ESSENTIEL</a>
				</div>

				<div class="price-card premium">
					<div class="badge-popular">LE PLUS POPULAIRE</div>
					<div class="card-header">
						<h3>Pack PREMIUM</h3>
						<div class="price">à partir de <span>549€</span></div>
						<p class="subtitle">Une expérience immersive et élégante.</p>
					</div>
					<ul class="features-list">
						<li><strong>Vidéo-booth 360 pendant 4h</strong></li>
						<li>Installation Premium (Espace esthétique)</li>
						<li><strong>1 à 2 animateurs professionnels</strong></li>
						<li><strong>Éclairage pro + Tapis rouge VIP</strong></li>
						<li><strong>Personnalisation vidéo</strong> (Logo, musique, thème)</li>
						<li>Accessoires Premium variés et élégants</li>
						<li>Machine à fumée légère ou bulles</li>
						<li>Partage instantané (Insta, TikTok, Snap...)</li>
						<li><strong>Sauvegarde complète</strong> (Lien de téléchargement)</li>
					</ul>
					<div class="ideal-for">
						<strong>Idéal pour :</strong> Mariages, Événements d'entreprise, Galas, Inaugurations.
					</div>
					<a href="/reservation" class="btn-card btn-card-premium">RÉSERVER LE PREMIUM</a>
				</div>
			</div>
		</div>
	</section>

	<section class="engagements-section">
		<div class="engagements-grid">
			<div>
				<h4>Élégance</h4>
				<p>Un design haut de gamme pour sublimer vos événements.</p>
			</div>
			<div>
				<h4>Qualité</h4>
				<p>Du matériel pro pour des finitions impeccables.</p>
			</div>
			<div>
				<h4>Sur-mesure</h4>
				<p>Des prestations adaptées à vos envies et à votre thème.</p>
			</div>
			<div>
				<h4>Souvenirs</h4>
				<p>Nous créons plus que des photos, nous créons des émotions.</p>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* --- STYLES DE BASE (ORDINATEUR) --- */
	.container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
	.text-center { text-align: center; }
	
	/* Héros */
	.hero-section { display: flex; padding: 60px 20px; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; gap: 40px; }
	.hero-text { flex: 1; }
	.hero-text p { color: #5A4636; margin: 20px 0 30px 0; font-size: 1.1rem; line-height: 1.6; }
	.hero-image { flex: 1; background-color: white; height: 400px; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: #CCC; font-style: italic; width: 100%; }

	/* Services */
	.services-section { background-color: var(--color-section); padding: 80px 20px; }
	.services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 50px; }
	.service-card { background-color: #FBF9F6; padding: 30px; border-radius: 4px; }
	.service-card h3 { font-size: 1.2rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent-dark); }
	.service-card p { font-size: 0.9rem; color: #5A4636; line-height: 1.6; margin: 15px 0; }
	.link-more { color: var(--color-text); font-size: 0.8rem; font-weight: bold; text-decoration: none; border-bottom: 1px solid var(--color-text); }

	/* TARIFS / PACKS */
	.pricing-section { padding: 80px 20px; background-color: var(--color-bg); }
	.pricing-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; max-width: 900px; margin: 0 auto; align-items: start; }
	
	.price-card { background: #FFFFFF; border: 1px solid rgba(203, 187, 160, 0.3); padding: 40px; border-radius: 8px; position: relative; box-shadow: 0 4px 20px rgba(0,0,0,0.02); display: flex; flex-direction: column; }
	
	/* Style spécifique pour le Pack Premium (VIP) */
	.price-card.premium { background: var(--color-text); /* Noir doux */ border: 1px solid var(--color-accent); color: var(--color-bg); transform: scale(1.03); /* Légèrement plus grand */ box-shadow: 0 10px 30px rgba(0,0,0,0.15); }
	
	.badge-popular { position: absolute; top: -15px; right: 30px; background: var(--color-accent); color: var(--color-text); font-size: 0.65rem; font-weight: bold; letter-spacing: 0.1em; padding: 6px 12px; border-radius: 20px; }

	.card-header h3 { margin-bottom: 10px; font-size: 1.8rem; }
	.premium .card-header h3 { color: var(--color-accent); } /* Titre doré pour le premium */
	
	.price { font-family: 'Playfair Display', serif; font-size: 1.2rem; color: var(--color-muted); margin-bottom: 5px; }
	.premium .price { color: var(--color-section); }
	.price span { font-size: 2.5rem; font-weight: bold; color: var(--color-text); }
	.premium .price span { color: #FFFFFF; }
	
	.subtitle { font-size: 0.85rem; font-style: italic; color: var(--color-muted); margin-bottom: 30px; }
	.premium .subtitle { color: var(--color-section); }

	.features-list { list-style: none; padding: 0; margin: 0 0 30px 0; border-top: 1px solid rgba(90, 70, 54, 0.1); }
	.premium .features-list { border-top-color: rgba(255,255,255,0.1); }
	.features-list li { padding: 12px 0; border-bottom: 1px solid rgba(90, 70, 54, 0.1); font-size: 0.9rem; }
	.premium .features-list li { border-bottom-color: rgba(255,255,255,0.1); }
	
	.ideal-for { font-size: 0.8rem; border-top: 1px solid rgba(90, 70, 54, 0.1); padding-top: 15px; margin-bottom: 30px; line-height: 1.4; color: var(--color-muted); }
	.premium .ideal-for { color: var(--color-section); border-top-color: rgba(255,255,255,0.1); }

	.btn-card { display: block; text-align: center; background: transparent; border: 1px solid var(--color-text); color: var(--color-text); text-decoration: none; padding: 14px; font-size: 0.8rem; font-weight: bold; letter-spacing: 0.1em; border-radius: 4px; transition: all 0.3s ease; }
	.btn-card:hover { background: var(--color-text); color: #FFFFFF; }
	
	.btn-card-premium { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-text); }
	.btn-card-premium:hover { background: #FFFFFF; border-color: #FFFFFF; color: var(--color-text); }

	/* Engagements */
	.engagements-section { background-color: var(--color-text); color: var(--color-bg); padding: 60px 20px; }
	.engagements-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; text-align: center; }
	.engagements-grid h4 { color: var(--color-accent); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.15em; }
	.engagements-grid p { font-size: 0.8rem; color: #CBBBA0; }

	/* --- MEDIA QUERIES (TABLETTE & MOBILE) --- */
	@media (max-width: 900px) {
		.services-grid { grid-template-columns: repeat(2, 1fr); }
		.engagements-grid { grid-template-columns: repeat(2, 1fr); }
		.pricing-grid { grid-template-columns: 1fr; gap: 50px; max-width: 500px; }
		.price-card.premium { transform: scale(1); } /* Enlève le zoom sur mobile pour éviter les bugs */
	}

	@media (max-width: 768px) {
		.hero-section { flex-direction: column; text-align: center; padding: 40px 20px; }
		.services-grid { grid-template-columns: 1fr; }
		.engagements-grid { grid-template-columns: 1fr; }
		h1 { font-size: 2.2rem; }
	}
</style>